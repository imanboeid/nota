# Xiaomi MiMo platform — get a key at https://platform.xiaomimimo.com
MIMO_API_KEY=mimo_sk_xxxxxxxxxxxxxxxx
MIMO_BASE_URL=https://platform.xiaomimimo.com/v1

# Model overrides (defaults are sensible).
MIMO_VISION_MODEL=mimo-v2.5-vision
MIMO_REASONING_MODEL=mimo-v2.5-reasoning
MIMO_TTS_MODEL=mimo-v2.5-tts

# Default voice for the weekly audio recap.
MIMO_TTS_VOICE=ember

# Currency display (rupiah by default, but the app is currency-agnostic).
PUBLIC_DEFAULT_CURRENCY=IDR
PUBLIC_DEFAULT_LOCALE=id-ID
