---
import { CATEGORY_META, formatIDR, type Receipt } from '../lib/types';

interface Props {
  receipt: Receipt;
  variant?: 'compact' | 'full';
}
const { receipt, variant = 'compact' } = Astro.props;
const meta = CATEGORY_META[receipt.category];

const flagBadge = {
  ok:    { label: 'Wajar',  tone: 'bg-emerald-50 text-emerald-700' },
  watch: { label: 'Cek dulu', tone: 'bg-amber-50 text-amber-700' },
  spike: { label: 'Tinggi',   tone: 'bg-rose-50 text-rose-700' }
}[receipt.flag];
---

<article class="pop p-5">
  <header class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2 text-[11px]">
        <span class={`chip ${meta.tint}`}>
          <span aria-hidden="true">{meta.emoji}</span>
          {meta.label}
        </span>
        <span class={`chip ${flagBadge.tone}`}>{flagBadge.label}</span>
        <span class="chip font-mono">{receipt.date}</span>
      </div>
      <h3 class="mt-3 truncate font-display text-lg font-semibold tracking-tight text-ink-800">
        {receipt.merchant.name}
      </h3>
      {receipt.merchant.location && (
        <p class="mt-0.5 truncate text-xs text-ink-400">{receipt.merchant.location}</p>
      )}
    </div>
    <div class="text-right">
      <div class="font-mono text-2xl font-semibold tracking-tightest text-ink-800">
        {formatIDR(receipt.total)}
      </div>
      {receipt.paymentMethod && (
        <div class="mt-1 text-[10px] uppercase tracking-[0.16em] text-ink-300">
          via {receipt.paymentMethod}
        </div>
      )}
    </div>
  </header>

  {variant === 'full' && (
    <ul class="mt-5 divide-y rule rounded-lg border rule">
      {receipt.items.map((item) => (
        <li class="flex items-center justify-between px-3 py-2 text-sm">
          <div class="min-w-0">
            <div class="truncate text-ink-700">{item.name}</div>
            {item.quantity > 1 && (
              <div class="text-[11px] text-ink-300">
                {item.quantity}× {item.unitPrice ? `@ ${formatIDR(item.unitPrice)}` : ''}
              </div>
            )}
          </div>
          <div class="num text-ink-700">{formatIDR(item.total)}</div>
        </li>
      ))}
    </ul>
  )}

  <p class="mt-4 rounded-lg border-l-2 border-ink-800 bg-bone-100/70 px-3 py-2 text-sm text-ink-600">
    <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-ink-300">
      Insight
    </span>
    <span class="ml-2">{receipt.insight}</span>
  </p>

  {variant === 'full' && (
    <footer class="mt-4 grid grid-cols-2 gap-3 border-t rule pt-4 text-[11px] text-ink-300">
      <div>
        <div class="uppercase tracking-[0.16em]">Vision tokens</div>
        <div class="mt-0.5 num text-ink-600">{receipt.tokens.vision.toLocaleString()}</div>
      </div>
      <div>
        <div class="uppercase tracking-[0.16em]">Reasoning tokens</div>
        <div class="mt-0.5 num text-ink-600">{receipt.tokens.reasoning.toLocaleString()}</div>
      </div>
    </footer>
  )}
</article>
