---
import Brandmark from './Brandmark.astro';

const path = Astro.url.pathname;
const links = [
  { href: '/scan',         label: 'Scan' },
  { href: '/ledger',       label: 'Ledger' },
  { href: '/how-it-works', label: 'How it works' },
  { href: '/about',        label: 'About' }
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-30 border-b rule bg-bone-50/85 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
    <a href="/" class="group inline-flex items-center gap-2.5 text-ink-800" aria-label="Nota — home">
      <span class="grid h-9 w-9 place-items-center rounded-xl bg-ink-800 shadow-edge">
        <Brandmark size={18} />
      </span>
      <span class="flex items-baseline gap-2">
        <span class="font-display text-xl font-semibold tracking-tightest">Nota</span>
        <span class="hidden text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300 sm:inline">
          v0.1 · live demo
          <span class="live-dot ml-1"></span>
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-3 py-1.5 text-sm font-medium transition',
            isActive(link.href)
              ? 'bg-ink-800 text-bone-50'
              : 'text-ink-400 hover:bg-bone-100 hover:text-ink-700'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="/scan"
      class="inline-flex items-center gap-1.5 rounded-md bg-lime-accent px-3.5 py-2 text-sm font-semibold text-ink-800 shadow-edge transition hover:bg-lime-accentDark"
    >
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 7V5a2 2 0 0 1 2-2h2"/>
        <path d="M17 3h2a2 2 0 0 1 2 2v2"/>
        <path d="M21 17v2a2 2 0 0 1-2 2h-2"/>
        <path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
        <path d="M7 12h10"/>
      </svg>
      Scan a receipt
    </a>
  </div>
</header>
