---
import Layout from '../layouts/Layout.astro';
import Brandmark from '../components/Brandmark.astro';
import ReceiptCard from '../components/ReceiptCard.astro';
import { SEED_RECEIPTS, SEED_TOTAL_IDR } from '../lib/seed';
import { formatIDR } from '../lib/types';

const featured = SEED_RECEIPTS.slice(0, 3);
---

<Layout>
  <!-- ── Hero ────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden border-b rule">
    <div class="pointer-events-none absolute inset-0 bg-grid-faint bg-[length:32px_32px] opacity-60"></div>

    <div class="relative mx-auto grid max-w-6xl items-center gap-10 px-5 pb-16 pt-14 sm:pt-20 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <span class="chip font-mono">
          <Brandmark size={14} />
          Built on Xiaomi MiMo
        </span>

        <h1 class="mt-5 h-display text-[clamp(2.4rem,5.2vw,4.4rem)] leading-[0.96]">
          Snap a struk.<br />
          <span class="bg-lime-accent px-2 -mx-2 inline-block">Sleep richer.</span>
        </h1>

        <p class="mt-6 max-w-lg text-lg text-ink-500">
          Drop any Indonesian receipt — Indomaret, GoFood, SPBU, kopi tetangga —
          and Nota reads it, categorises it, and tells you in one calm sentence
          what your wallet just did.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href="/scan"
            class="inline-flex items-center gap-2 rounded-md bg-ink-800 px-5 py-3 text-sm font-semibold text-bone-50 transition hover:bg-ink-700"
          >
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 7V5a2 2 0 0 1 2-2h2"/>
              <path d="M17 3h2a2 2 0 0 1 2 2v2"/>
              <path d="M21 17v2a2 2 0 0 1-2 2h-2"/>
              <path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
              <path d="M7 12h10"/>
            </svg>
            Try the scanner
          </a>
          <a
            href="/ledger"
            class="inline-flex items-center gap-2 rounded-md border rule bg-white px-5 py-3 text-sm font-semibold text-ink-700 transition hover:border-ink-400"
          >
            See a sample ledger →
          </a>
        </div>

        <dl class="mt-12 grid max-w-md grid-cols-3 gap-5">
          <div>
            <dt class="text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300">
              Last 3 receipts
            </dt>
            <dd class="mt-1 num text-2xl font-semibold tracking-tightest text-ink-800">
              {formatIDR(SEED_TOTAL_IDR)}
            </dd>
          </div>
          <div>
            <dt class="text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300">
              MiMo families
            </dt>
            <dd class="mt-1 num text-2xl font-semibold tracking-tightest text-ink-800">3</dd>
          </div>
          <div>
            <dt class="text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300">
              Account needed
            </dt>
            <dd class="mt-1 num text-2xl font-semibold tracking-tightest text-ink-800">0</dd>
          </div>
        </dl>
      </div>

      <!-- Mock device frame showing a parsed receipt -->
      <div class="relative">
        <div class="pop p-5">
          <div class="flex items-center justify-between text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300">
            <span class="inline-flex items-center gap-1.5">
              <span class="live-dot"></span> live · vision OCR
            </span>
            <span>~1.6s</span>
          </div>
          <div class="mt-4 rounded-xl border rule bg-bone-100/70 p-4">
            <div class="font-display text-base font-semibold text-ink-800">
              Indomaret Pekayon Raya
            </div>
            <div class="text-[11px] text-ink-400">Bekasi, Jawa Barat · 18 May 2026</div>
            <div class="mt-3 num text-3xl font-semibold tracking-tightest text-ink-800">
              {formatIDR(124300)}
            </div>
            <div class="mt-3 grid gap-1 font-mono text-[12px] text-ink-600">
              <div class="flex justify-between"><span>2 × Indomilk UHT 1L</span><span>37.800</span></div>
              <div class="flex justify-between"><span>5 × Indomie Goreng</span><span>17.500</span></div>
              <div class="flex justify-between"><span>1 × Telur 1kg</span><span>28.500</span></div>
              <div class="flex justify-between"><span>1 × Lifebuoy refill</span><span>19.500</span></div>
              <div class="flex justify-between"><span>6 × Aqua 600ml</span><span>21.000</span></div>
            </div>
          </div>
          <div class="mt-4 rounded-lg border-l-2 border-lime-accent bg-white px-3 py-2 text-sm text-ink-700">
            <span class="text-[10px] font-mono uppercase tracking-[0.16em] text-ink-300">Insight ·</span>
            Belanja minggu ini normal, dominan kebutuhan dapur dan air minum.
          </div>
        </div>

        <!-- Floating accent card -->
        <div class="pointer-events-none absolute -right-2 -top-3 hidden rotate-3 sm:block">
          <div class="rounded-md border rule bg-lime-accent px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-800 shadow-pop">
            mimo-v2.5-vision
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Why Nota ────────────────────────────────────────────────────────── -->
  <section class="border-b rule bg-white">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300">
        Why Nota
      </div>
      <h2 class="mt-2 h-display max-w-3xl text-3xl sm:text-4xl">
        Personal-finance apps make you log it. Nota just looks at the paper.
      </h2>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <div class="pop p-5">
          <div class="text-3xl">📸</div>
          <div class="mt-3 font-display text-lg font-semibold text-ink-800">
            Vision-first
          </div>
          <p class="mt-1 text-sm text-ink-400">
            Drop a photo. <span class="font-mono">mimo-v2.5-vision</span> reads
            line items, prices, totals — even from blurry struk.
          </p>
        </div>
        <div class="pop p-5">
          <div class="text-3xl">🧠</div>
          <div class="mt-3 font-display text-lg font-semibold text-ink-800">
            Reasoning, in Bahasa
          </div>
          <p class="mt-1 text-sm text-ink-400">
            Every receipt gets one warm Indonesian sentence — what's normal,
            what's a spike, what to watch.
          </p>
        </div>
        <div class="pop p-5">
          <div class="text-3xl">🔊</div>
          <div class="mt-3 font-display text-lg font-semibold text-ink-800">
            Weekly audio recap
          </div>
          <p class="mt-1 text-sm text-ink-400">
            Sundays, <span class="font-mono">mimo-v2.5-tts</span> reads you a
            60-second summary of how the week went.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Featured ledger ─────────────────────────────────────────────────── -->
  <section class="bg-bone-50">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <div class="flex items-end justify-between gap-4">
        <div>
          <div class="text-[11px] font-mono uppercase tracking-[0.16em] text-ink-300">
            Last three receipts
          </div>
          <h2 class="mt-2 h-display text-3xl sm:text-4xl">
            What Nota saw this week.
          </h2>
        </div>
        <a href="/ledger" class="hidden text-sm font-medium text-ink-500 hover:text-ink-800 sm:inline">
          Open ledger →
        </a>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {featured.map((r) => <ReceiptCard receipt={r} variant="compact" />)}
      </div>
    </div>
  </section>

  <!-- ── Final CTA ───────────────────────────────────────────────────────── -->
  <section class="border-t rule bg-ink-800 py-20 text-bone-50">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <div class="inline-grid h-12 w-12 place-items-center rounded-xl bg-lime-accent">
        <Brandmark size={22} />
      </div>
      <h2 class="mt-6 h-display text-4xl text-bone-50 sm:text-5xl">
        Stop guessing where the money went.
      </h2>
      <p class="mt-4 text-bone-200">
        Drop a receipt. See it parsed in 4 seconds. Coach yourself with a single
        Bahasa sentence.
      </p>
      <a
        href="/scan"
        class="mt-7 inline-flex items-center gap-2 rounded-md bg-lime-accent px-6 py-3.5 text-sm font-semibold text-ink-800 transition hover:bg-lime-accentDark"
      >
        Try the scanner →
      </a>
    </div>
  </section>
</Layout>
